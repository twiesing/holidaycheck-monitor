# --- Server ---
PORT=3000
HOST=127.0.0.1

# Path to the SQLite database file
DATABASE_PATH=./data/holidaycheck-monitor.sqlite

# Default cron expression for new watches (every 6 hours)
DEFAULT_CRON=0 */6 * * *

# --- Pushover (https://pushover.net) ---
# Create an application to get the token; your user key is on the dashboard.
# Leave empty to disable push notifications (changes are still recorded).
PUSHOVER_TOKEN=
PUSHOVER_USER=
# Optional: target a single device by its Pushover device name.
# Leave empty to deliver to all your devices.
PUSHOVER_DEVICE=

# --- Scraper ---
# Milliseconds to wait for offer API responses after navigation
SCRAPE_TIMEOUT_MS=45000
# Parallel independent page loads per check (cheapest across them wins).
# Higher = more robust against HolidayCheck serving a partial cached list.
SCRAPE_ATTEMPTS=4
# Delay (ms) between scheduled checks so watches with the same cron run
# one after another instead of all at once.
CHECK_DELAY_MS=30000
# Run the browser headless (set to "false" to debug visually)
HEADLESS=true
